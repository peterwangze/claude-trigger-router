    "js-yaml": "^4.1.0",
    "openurl": "^1.1.1",
    "rotating-file-stream": "^3.2.7",
    "tiktoken": "^1.0.21",
    "uuid": "^11.1.0",
    "lru-cache": "^10.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.15",
    "esbuild": "^0.25.1",
    "fastify": "^5.4.0",
    "shx": "^0.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.8.2",
